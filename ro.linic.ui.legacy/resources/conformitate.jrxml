	<detail>
		<band height="186" splitType="Stretch">
			<textField textAdjust="StretchHeight">
				<reportElement x="20" y="10" width="530" height="70" uuid="a62d43a1-ac7f-4a98-a652-250d14cdbc31"/>
				<textElement textAlignment="Justified">
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA["	Subsemnata "+$P{furnizorName}+", cu sediul în "+$P{furnizorDetails}+", declar pe propia răspundere că produsele de cofetărie-patiserie realizate în laboratorul nostru și livrate conform facturii nr "+$P{nrFactura}+" din data "+$P{dataFactura}.toString()+" sunt conforme cu normele de igienă, calitate și siguranță alimentară în vigoare."]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="20" y="80" width="530" height="50" uuid="afce39cb-e9b4-4ba2-9c8f-3e63e5e80c47"/>
				<textElement>
					<font size="12"/>
				</textElement>
				<text><![CDATA[	Produsele au fost realizate din materii prime conforme, depozitate și manipulate corespunzător, în spații igienizate, conform procedurilor interne de lucru și autocontrol.
	Produsele pot conține alergeni lapte, ouă, gluten, fructe etc.]]></text>
			</staticText>
			<textField textAdjust="StretchHeight">
				<reportElement x="20" y="130" width="530" height="20" uuid="c5062721-7384-4b30-a59e-b4530835d01e"/>
				<textElement>
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA["Data fabricației: "+$P{dataFactura}.toString()]]></textFieldExpression>
			</textField>
			<textField textAdjust="StretchHeight">
				<reportElement x="20" y="150" width="530" height="36" uuid="6c2afc52-e2f9-4f01-b37e-cfb2994246aa"/>
				<textElement>
					<font size="12"/>
				</textElement>
				<textFieldExpression><![CDATA["Termen de valabilitate:\n"+$P{termeneValabilitate}+"\nCondiții de păstrare: 2-4°C\n\nPrezenta declarație se eliberează pentru beneficiar: "+$P{customerName}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
